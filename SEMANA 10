import os

class Producto:
    def __init__(self, id, nombre, cantidad, precio):
        self.id = id
        self.nombre = nombre
        self.cantidad = cantidad
        self.precio = precio

    def __str__(self):
        return f"{self.id},{self.nombre},{self.cantidad},{self.precio}"

class Inventario:
    def __init__(self, archivo="inventario.txt"):
        self.archivo = archivo
        self.productos = {}
        self.cargar_desde_archivo()

    def cargar_desde_archivo(self):
        """Carga los datos del archivo al iniciar el programa."""
        try:
            if not os.path.exists(self.archivo):
                # Si no existe, lo creamos vacío
                with open(self.archivo, 'w') as f:
                    pass
                print(f"Archivo '{self.archivo}' creado exitosamente.")
                return

            with open(self.archivo, 'r') as f:
                for linea in f:
                    id_prod, nombre, cant, precio = linea.strip().split(',')
                    self.productos[id_prod] = Producto(id_prod, nombre, int(cant), float(precio))
            print("--- Inventario cargado correctamente desde el archivo. ---")
        
        except FileNotFoundError:
            print("Error: No se encontró el archivo.")
        except PermissionError:
            print("Error: No tienes permisos para leer el archivo.")
        except Exception as e:
            print(f"Error inesperado al cargar: {e}")

    def guardar_en_archivo(self):
        """Guarda el estado actual del diccionario en el archivo .txt"""
        try:
            with open(self.archivo, 'w') as f:
                for p in self.productos.values():
                    f.write(f"{p}\n")
        except PermissionError:
            print("Error: Permiso denegado al intentar escribir en el archivo.")
        except Exception as e:
            print(f"Error al guardar datos: {e}")

    def añadir_producto(self, producto):
        if producto.id in self.productos:
            print("Error: El ID ya existe.")
        else:
            self.productos[producto.id] = producto
            self.guardar_en_archivo()
            print(f"Producto '{producto.nombre}' añadido y guardado con éxito.")

    def actualizar_producto(self, id_prod, nueva_cantidad=None, nuevo_precio=None):
        if id_prod in self.productos:
            if nueva_cantidad is not None:
                self.productos[id_prod].cantidad = nueva_cantidad
            if nuevo_precio is not None:
                self.productos[id_prod].precio = nuevo_precio
            self.guardar_en_archivo()
            print(f"Producto ID {id_prod} actualizado en el archivo.")
        else:
            print("Producto no encontrado.")

    def eliminar_producto(self, id_prod):
        if id_prod in self.productos:
            del self.productos[id_prod]
            self.guardar_en_archivo()
            print(f"Producto ID {id_prod} eliminado del archivo.")
        else:
            print("Error: No se puede eliminar, el ID no existe.")

    def mostrar_inventario(self):
        if not self.productos:
            print("El inventario está vacío.")
        for p in self.productos.values():
            print(f"ID: {p.id} | Nombre: {p.nombre} | Cantidad: {p.cantidad} | Precio: ${p.precio}")

def menu():
    inv = Inventario()
    while True:
        print("\n--- SISTEMA DE GESTIÓN DE INVENTARIO ---")
        print("1. Añadir Producto")
        print("2. Eliminar Producto")
        print("3. Actualizar Producto")
        print("4. Mostrar Inventario")
        print("5. Salir")
        opcion = input("Seleccione una opción: ")

        if opcion == "1":
            id_p = input("ID: ")
            nom = input("Nombre: ")
            try:
                cant = int(input("Cantidad: "))
                pre = float(input("Precio: "))
                inv.añadir_producto(Producto(id_p, nom, cant, pre))
            except ValueError:
                print("Error: Cantidad y Precio deben ser números.")

        elif opcion == "2":
            id_p = input("ID del producto a eliminar: ")
            inv.eliminar_producto(id_p)

        elif opcion == "3":
            id_p = input("ID del producto a actualizar: ")
            try:
                cant = input("Nueva cantidad (deja vacío para no cambiar): ")
                pre = input("Nuevo precio (deja vacío para no cambiar): ")
                inv.actualizar_producto(
                    id_p, 
                    int(cant) if cant else None, 
                    float(pre) if pre else None
                )
            except ValueError:
                print("Error: Entrada no válida.")

        elif opcion == "4":
            inv.mostrar_inventario()

        elif opcion == "5":
            print("Saliendo del sistema...")
            break
        else:
            print("Opción no válida.")

if __name__ == "__main__":
    menu()
