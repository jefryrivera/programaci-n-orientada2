import tkinter as tk
from tkinter import messagebox

class TodoApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Gestor de Tareas - UEA")
        self.root.geometry("400x450")

        # Configuración de la interfaz
        self.setup_ui()

    def setup_ui(self):
        # Campo de entrada (Entry)
        self.task_entry = tk.Entry(self.root, font=("Arial", 12))
        self.task_entry.pack(pady=10, padx=20, fill=tk.X)
        
        # Evento: Presionar Enter para añadir tarea
        self.task_entry.bind('<Return>', lambda event: self.add_task())

        # Botones
        btn_frame = tk.Frame(self.root)
        btn_frame.pack(pady=5)

        tk.Button(btn_frame, text="Añadir Tarea", command=self.add_task, bg="#4caf50", fg="white").pack(side=tk.LEFT, padx=5)
        tk.Button(btn_frame, text="Marcar Completada", command=self.mark_completed, bg="#2196f3", fg="white").pack(side=tk.LEFT, padx=5)
        tk.Button(btn_frame, text="Eliminar Tarea", command=self.delete_task, bg="#f44336", fg="white").pack(side=tk.LEFT, padx=5)

        # Lista de tareas (Listbox)
        self.tasks_listbox = tk.Listbox(self.root, font=("Arial", 12), selectmode=tk.SINGLE)
        self.tasks_listbox.pack(pady=10, padx=20, fill=tk.BOTH, expand=True)
        
        # Opcional: Doble clic para marcar como completada
        self.tasks_listbox.bind('<Double-Button-1>', lambda event: self.mark_completed())

    def add_task(self):
        task = self.task_entry.get()
        if task != "":
            self.tasks_listbox.insert(tk.END, task)
            self.task_entry.delete(0, tk.END)
        else:
            messagebox.showwarning("Advertencia", "Debes escribir una tarea.")

    def mark_completed(self):
        try:
            index = self.tasks_listbox.curselection()[0]
            task = self.tasks_listbox.get(index)
            
            # Cambia el estado visualmente (añade un check o texto)
            if "✔" not in task:
                self.tasks_listbox.delete(index)
                self.tasks_listbox.insert(index, f"{task} ✔")
                self.tasks_listbox.itemconfig(index, fg="gray")
        except IndexError:
            messagebox.showwarning("Advertencia", "Selecciona una tarea para marcar.")

    def delete_task(self):
        try:
            index = self.tasks_listbox.curselection()[0]
            self.tasks_listbox.delete(index)
        except IndexError:
            messagebox.showwarning("Advertencia", "Selecciona una tarea para eliminar.")

if __name__ == "__main__":
    root = tk.Tk()
    app = TodoApp(root)
    root.mainloop()
