<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credixpres</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="header-celeste">
        <h1>CREDIXPRES</h1>
        <p>Todo empieza por ti</p>
    </header>

    <nav class="menu-horizontal">
        <div class="opcion" onclick="mostrarSeccion('pago')">
            <h3>Subir Pago</h3>
            <div class="circulo-icono">📄</div>
        </div>
        <div class="opcion" onclick="mostrarSeccion('contactanos')">
            <h3>Contáctanos</h3>
            <div class="circulo-icono">📞</div>
        </div>
        <div class="opcion" onclick="mostrarSeccion('soporte')">
            <h3>Soporte</h3>
            <div class="circulo-icono">🤖</div>
        </div>
        <div class="opcion" onclick="mostrarSeccion('historial')">
            <h3>Historial</h3>
            <div class="circulo-icono">📂</div>
        </div>
    </nav>

    <main class="contenido-blanco">
        
        <section id="seccion-pago" class="seccion-oculta">
            <h2>Tutorial: Cómo subir tu pago</h2>
            <p>1. Selecciona tu comprobante (PDF o PNG). 2. Rellena tus datos. 3. Haz clic en enviar.</p>
            
            <form action="mailto:administracion@credixpres.com" method="post" enctype="text/plain">
                <input type="file" accept=".pdf, .png" required>
                <input type="text" placeholder="Nombre y Apellido" required>
                <input type="text" placeholder="Cédula" required>
                <input type="tel" placeholder="Número de Teléfono" required>
                <input type="email" placeholder="Correo Electrónico" required>
                <button type="submit">Enviar Pago</button>
            </form>
        </section>

        <section id="seccion-contactanos" class="seccion-oculta">
            <h2>Beneficios de contactarnos</h2>
            <p>Atención personalizada, resolución inmediata de dudas y asesoría financiera directa.</p>
            <p>Escríbenos al WhatsApp: <strong>+593 98 150 8234</strong></p>
            <a href="https://wa.me/593981508234" target="_blank" class="link-google">Contactar por WhatsApp</a>
        </section>

        <section id="seccion-soporte" class="seccion-oculta">
            <h2>Asistente Virtual</h2>
            <div class="chat-simulado">
                <p><strong>IA:</strong> Hola, ¿en qué puedo ayudarte hoy?</p>
            </div>
            <p>Para emergencias técnicas: +593 98 150 8234</p>
        </section>

    </main>

    <script>
        function mostrarSeccion(id) {
            // Oculta todas las secciones
            document.querySelectorAll('section').forEach(s => s.style.display = 'none');
            // Muestra la seleccionada
            document.getElementById('seccion-' + id).style.display = 'block';
        }
    </script>
</body>
</html>
